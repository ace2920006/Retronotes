{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Next.js (Frontend)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/inkverse-frontend",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithEdge"
      }
    },
    {
      "name": "Debug NestJS (Backend)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/inkverse-backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug"],
      "console": "integratedTerminal",
      "restart": true,
      "autoAttachChildProcesses": true
    }
  ]
}

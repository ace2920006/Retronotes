// This is your Prisma schema file for MongoDB Atlas / MongoDB databases.
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  bio           String?
  banner        String?
  twitterUrl    String?
  mediumUrl     String?
  githubUrl     String?
  streak        Int       @default(0)
  lastWriteDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  notes         Note[]
  folders       Folder[]
  tags          Tag[]
  
  followers     Follow[] @relation("following")
  following     Follow[] @relation("follower")
  followedTags  TagFollow[]
  notifications Notification[]
  comments      Comment[]
  reactions     Reaction[]
  achievements  UserAchievement[]
  readingLists  ReadingList[]
}

model Folder {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  color     String?  // custom color styling
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     Note[]
}

model Tag {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteIds   String[] @db.ObjectId
  notes     Note[]   @relation(fields: [noteIds], references: [id])

  @@unique([name, userId])
}

model Note {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  title              String
  content            String
  isPinned           Boolean  @default(false)
  isArchived         Boolean  @default(false)
  isTrashed          Boolean  @default(false)
  isFavorite         Boolean  @default(false)
  isPublished        Boolean  @default(true)
  publishedAt        DateTime @default(now())
  viewsCount         Int      @default(0)
  uniqueReadersCount Int      @default(0)
  mood               String?
  summary            String?
  collection         String?  // Personal Journal, Ideas, Architecture, Notes, Quotes, Articles
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  userId             String   @db.ObjectId
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId           String?  @db.ObjectId
  folder             Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tagIds             String[] @db.ObjectId
  tags               Tag[]    @relation(fields: [tagIds], references: [id])
  color              String?

  seriesId           String?  @db.ObjectId
  series             Series?  @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  comments           Comment[]
  reactions          Reaction[]
  readingListIds     String[] @db.ObjectId
  readingLists       ReadingList[] @relation(fields: [readingListIds], references: [id])
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @db.ObjectId
  followingId String   @db.ObjectId
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model TagFollow {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tagName   String
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([tagName, userId])
}

model Reaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String   // LOVE, FIRE, INSIGHTFUL, CLAP, EMOTIONAL
  noteId    String   @db.ObjectId
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([noteId, userId, type])
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  noteId    String   @db.ObjectId
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  authorId  String   @db.ObjectId
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?  @db.ObjectId
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   Comment[] @relation("CommentReplies")
}

model Series {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  userId      String   @db.ObjectId
  createdAt   DateTime @default(now())
  notes       Note[]
}

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // FOLLOW, COMMENT, REACTION, PUBLISH, MENTION
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderId    String?
  senderName  String?
  senderImage String?
  noteId      String?
  commentId   String?
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model UserAchievement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  badgeId     String   // FIRST_NOTE, SEVEN_DAY_STREAK, HUNDRED_LIKES, FIFTY_NOTES, FIRST_COMMENT, FIRST_FOLLOWER
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlockedAt  DateTime @default(now())

  @@unique([badgeId, userId])
}

model ReadingList {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  noteIds     String[] @db.ObjectId
  notes       Note[]   @relation(fields: [noteIds], references: [id])
  createdAt   DateTime @default(now())
}


